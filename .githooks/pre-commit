#!/usr/bin/env bash
# Pre-commit hook: scan staged files for sensitive content before allowing commit.
# This is a PUBLIC repository — block commits that contain secrets or internal references.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v '^\.githooks/' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FAILED=0

check_pattern() {
  local description="$1"
  local pattern="$2"

  local matches
  matches=$(echo "$STAGED_FILES" | xargs grep -inE "$pattern" 2>/dev/null || true)

  if [ -n "$matches" ]; then
    if [ "$FAILED" -eq 0 ]; then
      echo -e "${RED}=== PUBLIC REPO SAFETY CHECK FAILED ===${NC}"
      echo ""
    fi
    echo -e "${YELLOW}[$description]${NC}"
    echo "$matches"
    echo ""
    FAILED=1
  fi
}

# API keys and tokens
check_pattern "AWS Access Key"                          'AKIA[0-9A-Z]{16}'
check_pattern "GitHub Personal Access Token"            'ghp_[a-zA-Z0-9]{36}'
check_pattern "GitHub OAuth Token"                      'gho_[a-zA-Z0-9]{36}'
check_pattern "API Secret Key (OpenAI/Anthropic/Stripe)" 'sk-[a-zA-Z0-9]{20,}'
check_pattern "Slack Token"                             'xox[bpras]-[a-zA-Z0-9-]{10,}'

# Generic secret patterns
check_pattern "Hardcoded password"  "password\s*[:=]\s*[\"'][^\"']{4,}"
check_pattern "Hardcoded secret"    "secret\s*[:=]\s*[\"'][^\"']{4,}"
check_pattern "Hardcoded token"     "token\s*[:=]\s*[\"'][^\"']{4,}"

# Private/internal references
check_pattern "Internal domain reference"      '\.internal\.'
check_pattern "Private IP address (10.x)"      '10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}'
check_pattern "Private IP address (172.16-31)" '172\.(1[6-9]|2[0-9]|3[01])\.[0-9]{1,3}\.[0-9]{1,3}'
check_pattern "Private IP address (192.168)"   '192\.168\.[0-9]{1,3}\.[0-9]{1,3}'

# Cross-vault references
check_pattern "Reference to private vault (second-brain)" 'second-brain'
check_pattern "Reference to private vault (work-vault)"   'work-vault'

if [ "$FAILED" -ne 0 ]; then
  echo -e "${RED}Commit blocked. Remove sensitive content before committing to this public repo.${NC}"
  echo "Use 'git commit --no-verify' to bypass (use with caution)."
  exit 1
fi
